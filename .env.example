# ─────────────────────────────────────────────
# OpenAI API Configuration
# ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here   # Your OpenAI API key
OPENAI_MODEL=gpt-5-mini                  # Model to use. gpt-4o-mini is recommended (low cost, good quality)
OPENAI_API_BASE=https://api.openai.com/v1 # API base URL. Replace this when using a third-party proxy

# ─────────────────────────────────────────────
# Whisper Speech Recognition Configuration
# ─────────────────────────────────────────────
WHISPER_MODEL=turbo       # Whisper model size: tiny / base / small / medium / large / turbo
SOURCE_LANGUAGE=English   # Language spoken in the video
TARGET_LANGUAGE=Chinese   # Language to translate subtitles into

# ─────────────────────────────────────────────
# Translation Chunking Configuration
# ─────────────────────────────────────────────
TRANSLATION_CHUNK_SIZE=20 # Number of subtitles sent to the API per request. Larger values reduce API calls but increase token usage per request
TRANSLATION_OVERLAP=5     # Number of extra subtitle lines included before and after each chunk for translation context

# ─────────────────────────────────────────────
# Subtitle Style Configuration
# ─────────────────────────────────────────────
SUBTITLE_PRIMARY_SIZE=18    # Primary subtitle font size (in points)
SUBTITLE_SECONDARY_SIZE=14  # Secondary subtitle font size (in points)

# Primary subtitle language: source = original on top / target = translation on top
SUBTITLE_PRIMARY_LANG=source

# Whether to show secondary subtitle: true = bilingual / false = primary only
SUBTITLE_SHOW_SECONDARY=true

# ─────────────────────────────────────────────
# Video Encoding Configuration
# ─────────────────────────────────────────────
# Hardware accelerator for FFmpeg video encoding: cpu | nvidia | amd | intel | mac
# cpu    -> libx264 / libx265
# nvidia -> h264_nvenc / hevc_nvenc        (requires NVIDIA GPU + NVENC driver)
# amd    -> h264_amf  / hevc_amf           (requires AMD GPU + AMF driver)
# intel  -> h264_qsv  / hevc_qsv           (requires Intel GPU + Media SDK)
# mac    -> h264_videotoolbox / hevc_videotoolbox  (requires macOS, Intel or Apple Silicon)
VIDEO_HW_ACCEL=cpu


